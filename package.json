{
  "name": "square-up",
  "version": "1.0.0",
  "description": "A word-arrangement puzzle: fit 12 words into a square where every side is a category and every corner belongs to two.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "npm run validate && vite build",
    "preview": "npm run build && wrangler dev",
    "validate": "node scripts/validate-puzzles.mjs",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "lz-string": "^1.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7",
    "wrangler": "^4.103.0"
  }
}
